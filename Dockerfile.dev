FROM node:22-slim AS deps
WORKDIR /app
COPY quartz/package.json quartz/package-lock.json ./
RUN npm ci

FROM node:22-slim
WORKDIR /app
COPY quartz/ ./
COPY --from=deps /app/node_modules ./node_modules
COPY assets/icon.png ./quartz/static/icon.png
COPY assets/icon.png ./quartz/static/og-image.png
EXPOSE 8080
CMD ["npx", "quartz", "build", "--serve"]
